{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KimaiTray",
  "version": "0.8.0",
  "identifier": "eu.engazan.kimaimate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "tray-popup",
        "title": "KimaiTray",
        "url": "/",
        "width": 360,
        "height": 640,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": true,
        "transparent": true
      },
      {
        "label": "settings",
        "title": "KimaiTray — Settings",
        "url": "/",
        "width": 780,
        "height": 600,
        "visible": false,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "Kimai time-tracking tray companion",
    "longDescription": "KimaiTray is a system tray companion for Kimai time tracking. Start, stop, pause, and switch timers without leaving your desktop. Supports multiple connections, idle detection, tags, and 5 languages.",
    "copyright": "Copyright (c) 2026 KimaiTray contributors",
    "publisher": "engazan",
    "homepage": "https://github.com/Engazan/KimaiTray",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "Slovak", "Czech", "German", "Ukrainian"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "exceptionDomain": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "section": "utils",
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4QUMzRDIxQTI1RUU5OUEKUldTYTZWNmlJVDJzdUdQZHRpRFpJVWNKZ1pndWs1Q3dFZ29DNzlJZlFJbm1WczZBVnNyTXdKVVIK",
      "endpoints": [
        "https://github.com/Engazan/KimaiTray/releases/latest/download/latest.json"
      ]
    }
  }
}
