{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for KimaiTray windows",
  "windows": ["tray-popup", "settings"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "store:default",
    "notification:default",
    "autostart:default",
    "log:default",
    "updater:default",
    "process:default"
  ]
}
